// =============================================
// Firebase Firestore Security Rules
// Paste these in: Firebase Console → Firestore → Rules
// =============================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /medicines/{docId} {
      // Anyone can read (needed for public listing)
      allow read: if true;

      // Anyone can create (no auth needed - low-barrier for Gaza)
      allow create: if
        request.resource.data.keys().hasAll(['medicine_en', 'contact', 'timestamp']) ||
        request.resource.data.keys().hasAll(['medicine_ar', 'contact', 'timestamp']);

      // Only allow updating flag_count (for flagging feature)
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flag_count']);

      // No deletes from client (admin only via console)
      allow delete: if false;
    }
  }
}
